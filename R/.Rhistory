y = Sequence,
fill = Color
)) +
geom_tile() +
geom_hline(yintercept = hline_positions, color = "#ffffbf", size = 0.5) +
scale_fill_identity() +
theme_minimal() +
labs(x = "Position vs reference", y = "Sequence") +
theme(panel.grid = element_blank())
